#include <Arduino.h>
#include <SPI.h>
#include <SD.h>
#include <MFRC522.h>

// ---------------- PINS LECTOR SD ----------------
#define SD_CS   39
#define SD_MOSI 35
#define SD_SCK  36
#define SD_MISO 37

// ---------------- PINS LECTOR RFID ----------------
#define RFID_RST  9
#define RFID_MISO 13
#define RFID_MOSI 11
#define RFID_SCK  12
#define RFID_CS   10 // Aquest és el SDA

// Creem un SEGON bus SPI exclusiu per a la targeta SD
SPIClass spiSD(FSPI); 

// L'objecte RFID utilitzarà el bus SPI principal per defecte
MFRC522 mfrc522(RFID_CS, RFID_RST);

void setup() {
  Serial.begin(115200);
  while (!Serial) { delay(10); } // Esperem que s'obri el Monitor Sèrie
  delay(1000);

  Serial.println("\n--- INICIANT DATALOGGER (DOBLE BUS SPI) ---");

  // 1. Inicialitzem el bus SPI PRINCIPAL (pels pins del RFID)
  SPI.begin(RFID_SCK, RFID_MISO, RFID_MOSI, RFID_CS);
  mfrc522.PCD_Init();
  Serial.println("✅ Lector RFID iniciat (Bus 1)");

  // 2. Inicialitzem el bus SPI SECUNDARI (pels pins de la SD)
  spiSD.begin(SD_SCK, SD_MISO, SD_MOSI, SD_CS);
  
  Serial.print("Iniciant targeta SD... ");
  // Molt important: passem 'spiSD' com a segon paràmetre perquè la SD sàpiga quins cables usar
  if (!SD.begin(SD_CS, spiSD)) {
    Serial.println("❌ ERROR: No s'ha pogut iniciar la SD.");
  } else {
    Serial.println("✅ OK (Bus 2)");
  }

  Serial.println("-------------------------------------------");
  Serial.println("Apropa una targeta per registrar-la a fichero.log");
}

void loop() {
  // Revisem si hi ha targeta
  if (mfrc522.PICC_IsNewCardPresent() && mfrc522.PICC_ReadCardSerial()) {
    
    // Transformem l'UID llegit a una cadena de text
    String uidString = "";
    for (byte i = 0; i < mfrc522.uid.size; i++) {
      uidString += String(mfrc522.uid.uidByte[i] < 0x10 ? " 0" : " ");
      uidString += String(mfrc522.uid.uidByte[i], HEX);
    }
    uidString.toUpperCase();
    
    // Agafem "l'hora" com els segons que fa que la placa està encesa
    unsigned long tempsSegons = millis() / 1000; 

    // Formatem la línia exacta que escriurem al fitxer
    String registre = "Temps: " + String(tempsSegons) + "s | Codi:" + uidString;
    Serial.print("Llegit: " + registre);

    // Obrim la SD en mode afegir (FILE_APPEND)
    File myFile = SD.open("/fichero.log", FILE_APPEND);
    
    if (myFile) {
      myFile.println(registre); // Guardem a la SD
      myFile.close();           // Tanquem sempre el fitxer!
      Serial.println("  --> 💾 Guardat a fichero.log");
    } else {
      Serial.println("  --> ❌ Error obrint fichero.log");
    }

    // Aturem la lectura actual per evitar dobles lectures ràpides
    mfrc522.PICC_HaltA(); 
    delay(1000); 
  }
}
